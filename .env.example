# Required
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=replace_with_a_long_random_secret
SPREADSHEET_ID=your_google_spreadsheet_id

GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n

# Optional
PORT=10000
APP_TIMEZONE=Asia/Phnom_Penh
SUPER_ADMINS=yourtelegramusername

# Runtime / HTTP
TELEGRAM_TIMEOUT_MS=15000

# Cache
SHEET_CACHE_TTL_MS=5000
PROCESSED_MESSAGE_TTL_MS=1800000
PROCESSED_MESSAGE_CACHE_LIMIT=5000

# Confirm / Undo
CONFIRM_EXPIRE_MINUTES=10
UNDO_WINDOW_MINUTES=30

# Rate Limit
RATE_LIMIT_WINDOW_MS=2000
RATE_LIMIT_MAX_WRITES=3

# Retention / Cleanup
PROCESSED_MESSAGE_RETENTION_DAYS=14
PENDING_ACTION_RETENTION_DAYS=30
CLEANUP_INTERVAL_MS=600000

# Daily Report
DAILY_REPORT_HOUR=8
DAILY_REPORT_MINUTE=0
DAILY_REPORT_CHECK_INTERVAL_MS=60000

# Input Session
INPUT_SESSION_TIMEOUT_MS=600000

# RENDER NOTE:
# Run only 1 instance/service for this bot.
# GOOGLE_PRIVATE_KEY should stay on one line with literal \n characters.
